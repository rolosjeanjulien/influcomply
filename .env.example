# =============================================================================
# BASE DE DONNÉES - Supabase / PostgreSQL
# =============================================================================

# URL de connexion via le pooler (Transaction mode) - utilisée par Prisma en runtime
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# URL de connexion directe - utilisée pour les migrations Prisma
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# =============================================================================
# SUPABASE - Client JS
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[ANON-KEY]"
SUPABASE_SERVICE_ROLE_KEY="[SERVICE-ROLE-KEY]"

# =============================================================================
# APPLICATION
# =============================================================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# =============================================================================
# ANTHROPIC - Claude API (REQ-REG-003, REQ-SCN-004, REQ-SCN-008)
# =============================================================================
ANTHROPIC_API_KEY="[ANTHROPIC-API-KEY]"

# =============================================================================
# RESEND - Emails transactionnels
# =============================================================================
RESEND_API_KEY="[RESEND-API-KEY]"
RESEND_FROM_EMAIL="noreply@influcomply.fr"

# =============================================================================
# TRIGGER.DEV - Jobs asynchrones (REQ-CRT-001, REQ-SCN-007)
# =============================================================================
TRIGGER_SECRET_KEY="[TRIGGER-SECRET-KEY]"
NEXT_PUBLIC_TRIGGER_PUBLIC_API_KEY="[TRIGGER-PUBLIC-KEY]"

# =============================================================================
# YOUSIGN - Signature électronique (REQ-CTR-004)
# =============================================================================
YOUSIGN_API_KEY="[YOUSIGN-API-KEY]"
YOUSIGN_WEBHOOK_SECRET="[YOUSIGN-WEBHOOK-SECRET]"
YOUSIGN_BASE_URL="https://api.yousign.app/v3"

# =============================================================================
# UPSTASH REDIS - Cache & rate limiting (REQ-CRT-002, REQ-NFR-001)
# =============================================================================
UPSTASH_REDIS_REST_URL="[UPSTASH-REDIS-URL]"
UPSTASH_REDIS_REST_TOKEN="[UPSTASH-REDIS-TOKEN]"
