generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// USERS & ORGANISATIONS
// ─────────────────────────────────────────────

model User {
  id         String   @id @default(cuid())
  email      String   @unique
  name       String?
  avatarUrl  String?  @map("avatar_url")
  role       UserRole @default(CREATOR)
  supabaseId String?  @unique @map("supabase_id")
  isPublic   Boolean  @default(false) @map("is_public")
  slug       String?  @unique
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  organizationMembers OrganizationMember[]
  socialAccounts      SocialAccount[]
  publications        Publication[]
  complianceScores    ComplianceScore[]
  badge               Badge?
  contracts           Contract[]
  apiKeys             ApiKey[]
  scanAlerts          ScanAlert[]

  @@map("users")
}

enum UserRole {
  CREATOR
  AGENCY
  ADVERTISER
  ADMIN
}

model Organization {
  id          String           @id @default(cuid())
  name        String
  slug        String           @unique
  type        OrganizationType
  siret       String?
  siretStatus SiretStatus?     @map("siret_status")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  members   OrganizationMember[]
  contracts Contract[]
  webhooks  WebhookEndpoint[]
  apiKeys   ApiKey[]

  @@map("organizations")
}

enum OrganizationType {
  AGENCY
  ADVERTISER
}

enum SiretStatus {
  VALID
  INVALID
  PENDING
}

model OrganizationMember {
  id             String        @id @default(cuid())
  userId         String        @map("user_id")
  organizationId String        @map("organization_id")
  role           OrgMemberRole @default(MEMBER)
  createdAt      DateTime      @default(now()) @map("created_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@map("organization_members")
}

enum OrgMemberRole {
  OWNER
  ADMIN
  MEMBER
}

// ─────────────────────────────────────────────
// SCN — SCANNER DE PUBLICATIONS
// REQ-SCN-001, REQ-SCN-002, REQ-SCN-003
// ─────────────────────────────────────────────

model SocialAccount {
  id             String    @id @default(cuid())
  userId         String    @map("user_id")
  platform       Platform
  accountId      String    @map("account_id")
  username       String
  followerCount  Int?      @map("follower_count")
  accessToken    String?   @map("access_token") // chiffré AES-256
  refreshToken   String?   @map("refresh_token") // chiffré AES-256
  tokenExpiresAt DateTime? @map("token_expires_at")
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  publications Publication[]

  @@unique([userId, platform, accountId])
  @@map("social_accounts")
}

enum Platform {
  INSTAGRAM
  TIKTOK
  YOUTUBE
}

model Publication {
  id              String       @id @default(cuid())
  userId          String       @map("user_id")
  socialAccountId String?      @map("social_account_id")
  platform        Platform
  externalId      String?      @map("external_id")
  url             String?
  content         String?
  mediaUrls       String[]     @map("media_urls")
  publishedAt     DateTime?    @map("published_at")
  importMethod    ImportMethod @map("import_method")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  socialAccount SocialAccount? @relation(fields: [socialAccountId], references: [id])
  scanResults   ScanResult[]

  @@map("publications")
}

enum ImportMethod {
  OAUTH
  EXTENSION
  MANUAL_URL
  MANUAL_SCREENSHOT
  MANUAL_TEXT
}

// REQ-SCN-004, REQ-SCN-005, REQ-SCN-006
model ScanResult {
  id              String     @id @default(cuid())
  publicationId   String     @map("publication_id")
  score           Int // 0–100
  adMentionScore  Int?       @map("ad_mention_score") // /40 — REQ-SCN-004
  prohibitedScore Int?       @map("prohibited_score") // /30 — REQ-SCN-005
  retouchScore    Int?       @map("retouch_score") // /15 — REQ-SCN-009
  status          ScanStatus @default(PENDING)
  rawAnalysis     Json?      @map("raw_analysis")
  scannedAt       DateTime   @default(now()) @map("scanned_at")

  publication     Publication     @relation(fields: [publicationId], references: [id], onDelete: Cascade)
  nonConformities NonConformity[]
  alerts          ScanAlert[]

  @@map("scan_results")
}

enum ScanStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model NonConformity {
  id           String            @id @default(cuid())
  scanResultId String            @map("scan_result_id")
  type         NonConformityType
  severity     Severity
  description  String
  suggestion   String? // REQ-SCN-008
  isResolved   Boolean           @default(false) @map("is_resolved")
  resolvedAt   DateTime?         @map("resolved_at")
  createdAt    DateTime          @default(now()) @map("created_at")

  scanResult ScanResult @relation(fields: [scanResultId], references: [id], onDelete: Cascade)

  @@map("non_conformities")
}

enum NonConformityType {
  MISSING_AD_MENTION // REQ-SCN-004 — loi 2023-451 art. 5
  PROHIBITED_PRODUCT // REQ-SCN-005
  RETOUCHED_IMAGE // REQ-SCN-009
  OTHER
}

enum Severity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

// REQ-SCN-007
model ScanAlert {
  id           String    @id @default(cuid())
  scanResultId String    @map("scan_result_id")
  userId       String    @map("user_id")
  type         AlertType
  message      String
  isRead       Boolean   @default(false) @map("is_read")
  sentAt       DateTime  @default(now()) @map("sent_at")

  scanResult ScanResult @relation(fields: [scanResultId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("scan_alerts")
}

enum AlertType {
  NON_CONFORMITY
  SCORE_DROP
  BADGE_REVOKED
  BADGE_AWARDED
  CONTRACT_THRESHOLD
  REGULATION_UPDATE
}

// ─────────────────────────────────────────────
// DSH — DASHBOARD DE CONFORMITÉ
// REQ-DSH-001, REQ-DSH-002, REQ-DSH-003, REQ-DSH-006
// ─────────────────────────────────────────────

model ComplianceScore {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  date      DateTime @db.Date
  score     Int // 0–100
  scanCount Int      @default(0) @map("scan_count")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("compliance_scores")
}

// REQ-DSH-003
model AuditReport {
  id          String   @id @default(cuid())
  userId      String?  @map("user_id")
  orgId       String?  @map("org_id")
  periodStart DateTime @map("period_start")
  periodEnd   DateTime @map("period_end")
  fileUrl     String?  @map("file_url")
  generatedAt DateTime @default(now()) @map("generated_at")

  @@map("audit_reports")
}

// ─────────────────────────────────────────────
// CTR — CONTRACT FACTORY
// REQ-CTR-001, REQ-CTR-002, REQ-CTR-003
// ─────────────────────────────────────────────

model ContractTemplate {
  id        String            @id @default(cuid())
  name      String
  type      CollaborationType
  content   String // template Handlebars
  version   String            @default("1.0")
  isActive  Boolean           @default(true) @map("is_active")
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")

  contracts Contract[]

  @@map("contract_templates")
}

enum CollaborationType {
  GIFTING
  PAID_PARTNERSHIP
  BRAND_AMBASSADOR
}

// REQ-CTR-001, REQ-CTR-004, REQ-CTR-007
model Contract {
  id             String            @id @default(cuid())
  creatorId      String            @map("creator_id")
  organizationId String            @map("organization_id")
  templateId     String?           @map("template_id")
  type           CollaborationType
  status         ContractStatus    @default(DRAFT)
  amount         Float? // montant HT en EUR
  currency       String            @default("EUR")
  startDate      DateTime?         @map("start_date")
  endDate        DateTime?         @map("end_date")
  yousignId      String?           @map("yousign_id") // REQ-CTR-004
  fileUrl        String?           @map("file_url") // Supabase Storage
  fileHash       String?           @map("file_hash") // SHA-256 — REQ-CTR-007
  signedAt       DateTime?         @map("signed_at")
  expiresAt      DateTime?         @map("expires_at")
  archivedAt     DateTime?         @map("archived_at")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  creator      User              @relation(fields: [creatorId], references: [id])
  organization Organization      @relation(fields: [organizationId], references: [id])
  template     ContractTemplate? @relation(fields: [templateId], references: [id])

  @@map("contracts")
}

enum ContractStatus {
  DRAFT
  PENDING_SIGNATURE
  SIGNED
  ACTIVE
  EXPIRED
  TERMINATED
}

// REQ-CTR-003 — suivi seuil €1 000 HT annuel
model GiftingLedger {
  id             String   @id @default(cuid())
  creatorId      String   @map("creator_id")
  organizationId String   @map("organization_id")
  amount         Float
  description    String?
  date           DateTime @db.Date
  year           Int
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("gifting_ledger")
}

// ─────────────────────────────────────────────
// REG — VEILLE RÉGLEMENTAIRE
// REQ-REG-001, REQ-REG-002, REQ-REG-003, REQ-REG-005
// ─────────────────────────────────────────────

// REQ-REG-001 — base de connaissances juridiques vectorisée
model RegulatoryText {
  id          String      @id @default(cuid())
  title       String
  type        RegTextType
  source      String // JORF, DGCCRF, ARPP…
  url         String?
  content     String
  publishedAt DateTime    @map("published_at")
  isActive    Boolean     @default(true) @map("is_active")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  chunks RegulatoryTextChunk[]

  @@map("regulatory_texts")
}

enum RegTextType {
  LAW
  DECREE
  ORDINANCE
  GUIDE
  POSITION
  CERTIFICATE
}

model RegulatoryTextChunk {
  id         String   @id @default(cuid())
  textId     String   @map("text_id")
  content    String
  chunkIndex Int      @map("chunk_index")
  // embedding pgvector géré via SQL raw (ALTER TABLE ADD COLUMN embedding vector(1536))
  createdAt  DateTime @default(now()) @map("created_at")

  text RegulatoryText @relation(fields: [textId], references: [id], onDelete: Cascade)

  @@map("regulatory_text_chunks")
}

// REQ-REG-002 — alertes réglementaires
model RegulatoryAlert {
  id          String    @id @default(cuid())
  textId      String?   @map("text_id")
  title       String
  summary     String
  source      String
  url         String?
  publishedAt DateTime  @map("published_at")
  isValidated Boolean   @default(false) @map("is_validated")
  notifiedAt  DateTime? @map("notified_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("regulatory_alerts")
}

// REQ-REG-005 — moteur de règles configurable
model ComplianceRule {
  id          String          @id @default(cuid())
  code        String          @unique
  name        String
  description String
  pattern     String?
  patternType RulePatternType @map("pattern_type")
  severity    Severity
  legalRef    String?         @map("legal_ref")
  isActive    Boolean         @default(true) @map("is_active")
  version     Int             @default(1)
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  @@map("compliance_rules")
}

enum RulePatternType {
  REGEX
  SEMANTIC
  HYBRID
}

// ─────────────────────────────────────────────
// CRT — CERTIFICATION & BADGE
// REQ-CRT-001, REQ-CRT-002, REQ-CRT-004
// ─────────────────────────────────────────────

// REQ-CRT-001, REQ-CRT-004
model Badge {
  id             String      @id @default(cuid())
  userId         String      @unique @map("user_id")
  status         BadgeStatus @default(NONE)
  certifiedSince DateTime?   @map("certified_since")
  revokedAt      DateTime?   @map("revoked_at")
  lastCheckedAt  DateTime?   @map("last_checked_at")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  history BadgeHistory[]

  @@map("badges")
}

enum BadgeStatus {
  NONE
  ELIGIBLE
  CERTIFIED
  REVOKED
}

model BadgeHistory {
  id        String      @id @default(cuid())
  badgeId   String      @map("badge_id")
  status    BadgeStatus
  reason    String?
  score     Int?
  changedAt DateTime    @default(now()) @map("changed_at")

  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@map("badge_history")
}

// ─────────────────────────────────────────────
// INT — INTÉGRATIONS
// REQ-INT-001, REQ-INT-002
// ─────────────────────────────────────────────

// REQ-INT-001 — API partenaires
model ApiKey {
  id             String    @id @default(cuid())
  userId         String?   @map("user_id")
  organizationId String?   @map("organization_id")
  name           String
  keyHash        String    @unique @map("key_hash") // clé hachée
  prefix         String // 8 premiers chars pour affichage
  tier           ApiTier   @default(FREE)
  lastUsedAt     DateTime? @map("last_used_at")
  expiresAt      DateTime? @map("expires_at")
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime  @default(now()) @map("created_at")

  user         User?         @relation(fields: [userId], references: [id])
  organization Organization? @relation(fields: [organizationId], references: [id])

  @@map("api_keys")
}

enum ApiTier {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

// REQ-INT-002 — webhooks sortants
model WebhookEndpoint {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  url            String
  secret         String // secret HMAC-SHA256
  events         String[]
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  deliveries   WebhookDelivery[]

  @@map("webhook_endpoints")
}

model WebhookDelivery {
  id           String         @id @default(cuid())
  endpointId   String         @map("endpoint_id")
  event        String
  payload      Json
  status       DeliveryStatus @default(PENDING)
  attempts     Int            @default(0)
  nextRetryAt  DateTime?      @map("next_retry_at")
  responseCode Int?           @map("response_code")
  deliveredAt  DateTime?      @map("delivered_at")
  createdAt    DateTime       @default(now()) @map("created_at")

  endpoint WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@map("webhook_deliveries")
}

enum DeliveryStatus {
  PENDING
  DELIVERED
  FAILED
  RETRYING
}
